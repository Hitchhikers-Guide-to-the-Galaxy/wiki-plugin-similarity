{
  "name": "wiki-plugin-similarity",
  "version": "0.9.0",
  "description": "Federated Wiki plugin \u2014 semantic similarity search across wiki domains using prebuilt vector indexes",
  "keywords": [
    "wiki",
    "federated wiki",
    "plugin",
    "similarity",
    "semantic search",
    "embeddings"
  ],
  "author": {
    "name": "David Bovill",
    "url": "https://github.com/Hitchhikers-Guide-to-the-Galaxy"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "client",
    "server",
    "pages",
    "factory.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hitchhikers-Guide-to-the-Galaxy/wiki-plugin-similarity.git"
  },
  "bugs": {
    "url": "https://github.com/Hitchhikers-Guide-to-the-Galaxy/wiki-plugin-similarity/issues"
  },
  "homepage": "https://github.com/Hitchhikers-Guide-to-the-Galaxy/wiki-plugin-similarity#readme",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "build": "npm run clean && npm run test && node --no-warnings scripts/build-client.js",
    "dev": "node --no-warnings scripts/build-client.js --watch",
    "about": "wiki -p 3010 -d . --security_legacy",
    "clean": "rm -f client/similarity.js client/similarity.js.map",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "minisearch": "^7.2.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-web": "1.14.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}